# Copy to .env locally, OR set these as Render environment variables on the dashboard.

# Required
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxx
SHARED_PASSWORD=set-a-strong-password-here
JWT_SECRET=set-a-long-random-string-here

# Optional — defaults shown
PORT=3000
APIFY_ACTOR=apify~rag-web-browser
DATA_DIR=./data
OUTPUT_DIR=./outputs
MAX_QUERIES_PER_BRIEF=12
MAX_RESULTS_PER_QUERY=20
ALLOWED_ORIGINS=https://rjp-sourcing.netlify.app,http://localhost:5500

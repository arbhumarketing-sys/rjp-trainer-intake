# Copy to .env locally, OR set these as Render environment variables on the dashboard.

# ===== Required =====
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxx
SHARED_PASSWORD=set-a-strong-password-here
JWT_SECRET=set-a-long-random-string-here

# ===== v3.1: Claude API (recommended — enables L1.1, L2 adjacent-tech, L3 institutes, free-text intake) =====
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001
CLAUDE_MODEL_SMART=claude-sonnet-4-5

# ===== Apify actors (defaults shown) =====
APIFY_GOOGLE_ACTOR=apify~rag-web-browser
APIFY_LINKEDIN_ACTOR=harvestapi/linkedin-profile-scraper

# ===== Pipeline tuning =====
PORT=3000
DATA_DIR=./data
OUTPUT_DIR=./outputs
MAX_QUERIES_STD=12
MAX_QUERIES_NICHE=20
MAX_RESULTS_PER_QUERY=15
QUALITY_CAP=15

# ===== CORS — set to your Vercel/Netlify URL =====
ALLOWED_ORIGINS=https://rjp-trainer-intake.vercel.app,http://localhost:5500

# ===== Dev / test =====
# MOCK_APIFY=1               # use synthetic results instead of burning Apify credits
# RELOAD_SEED=1              # force re-load seed-briefs.json on every boot

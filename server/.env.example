# Copy to .env locally, OR set these as Render environment variables on the dashboard.

# ===== Required =====
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxx
SHARED_PASSWORD=set-a-strong-password-here
JWT_SECRET=set-a-long-random-string-here

# ===== v3.1: Claude integration (enables L1.1 knowledge, L2 adjacent-tech, L3 institutes, free-text intake) =====
# Pick ONE of the two paths below.
#
# Path A — bill against Claude Max subscription via the `claude` CLI (no API credits needed):
#   1) Install Claude Code: `npm install -g @anthropic-ai/claude-code`  (Render does this in buildCommand).
#   2) On the operator's Mac, run `claude setup-token` to mint a long-lived
#      OAuth token, then paste it as CLAUDE_CODE_OAUTH_TOKEN below.
ANTHROPIC_VIA_CLAUDE_CLI=true
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-xxxxxxxxxxxxxxxxxxxx
#
# Path B — pay-as-you-go API console credits (alternative; remove the two lines above):
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001
CLAUDE_MODEL_SMART=claude-sonnet-4-5

# ===== Apify actors (defaults shown) =====
APIFY_GOOGLE_ACTOR=apify~rag-web-browser
APIFY_LINKEDIN_ACTOR=harvestapi/linkedin-profile-scraper

# ===== Pipeline tuning =====
PORT=3000
DATA_DIR=./data
OUTPUT_DIR=./outputs
MAX_QUERIES_STD=12
MAX_QUERIES_NICHE=20
MAX_RESULTS_PER_QUERY=15
QUALITY_CAP=15
LINKEDIN_ENRICH_CAP=60

# ===== v3.2 resilience knobs =====
# BRIEF_STUCK_TIMEOUT_MS=1500000   # 25 min; watchdog auto-fails briefs stuck this long
# WATCHDOG_INTERVAL_MS=60000       # how often the watchdog scans
# RECONCILE_INTERVAL_MS=300000     # 5 min; Postgres dirty-write retry tick
# LOW_YIELD_THRESHOLD=3            # ↓ this many candidates → low-yield warning to UI

# ===== v3.2 quality knobs =====
# LLM_CLASSIFIER_BATCH_SIZE=15     # profiles per Haiku classification call
# DISABLE_LLM_CLASSIFIER=1         # fall back to regex-only (no LLM cost)
# WEB_VERIFY_TOP_N=20              # top accepted candidates to web-verify
# WEB_VERIFY_CONCURRENCY=3         # parallel Apify queries during verify
# WEB_VERIFY_BOOST=5               # score delta for 2+ verification hits
# WEB_VERIFY_DEMOTE=3              # score delta for 0 verification hits
# DISABLE_WEB_VERIFY=1             # skip the verify pass entirely
# RERANK_TOP_N=30                  # candidates sent to Sonnet for holistic rerank
# DISABLE_RERANK=1                 # skip the rerank pass
# DISABLE_PREFLIGHT_CHECK=1        # skip the pre-flight defensibility check

# ===== CORS — set to your Vercel/Netlify URL =====
ALLOWED_ORIGINS=https://rjp-trainer-intake.vercel.app,http://localhost:5500

# ===== Dev / test =====
# MOCK_APIFY=1               # use synthetic results instead of burning Apify credits
# RELOAD_SEED=1              # force re-load seed-briefs.json on every boot
